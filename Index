<script>
// BACKGROUND
const canvas=document.getElementById('bg-canvas'),ctx=canvas.getContext('2d');
function resize(){canvas.width=window.innerWidth;canvas.height=window.innerHeight;}
resize();window.addEventListener('resize',resize);
const shapes=[];
for(let i=0;i<18;i++){
  const types=['circle','ring','rect','triangle'];
  const cols=['rgba(249,115,22,','rgba(251,146,60,','rgba(253,186,116,','rgba(234,88,12,','rgba(255,228,180,'];
  shapes.push({type:types[Math.floor(Math.random()*4)],x:Math.random()*1400,y:Math.random()*900,size:30+Math.random()*120,alpha:0.03+Math.random()*0.08,color:cols[Math.floor(Math.random()*5)],vx:(Math.random()-.5)*.3,vy:(Math.random()-.5)*.3,rot:Math.random()*Math.PI*2,vr:(Math.random()-.5)*.005,pulse:Math.random()*Math.PI*2,ps:.005+Math.random()*.01});
}
(function animate(){
  ctx.clearRect(0,0,canvas.width,canvas.height);
  shapes.forEach(s=>{
    s.x+=s.vx;s.y+=s.vy;s.rot+=s.vr;s.pulse+=s.ps;
    if(s.x<-200)s.x=canvas.width+200;if(s.x>canvas.width+200)s.x=-200;
    if(s.y<-200)s.y=canvas.height+200;if(s.y>canvas.height+200)s.y=-200;
    const p=1+Math.sin(s.pulse)*.1,sz=s.size*p,a=s.alpha*(.85+Math.sin(s.pulse)*.15);
    ctx.save();ctx.translate(s.x,s.y);ctx.rotate(s.rot);ctx.globalAlpha=a;
    if(s.type==='circle'){ctx.beginPath();ctx.arc(0,0,sz/2,0,Math.PI*2);ctx.fillStyle=s.color+a+')';ctx.fill();}
    else if(s.type==='ring'){ctx.beginPath();ctx.arc(0,0,sz/2,0,Math.PI*2);ctx.strokeStyle=s.color+(a*2)+')';ctx.lineWidth=2;ctx.stroke();}
    else if(s.type==='rect'){ctx.fillStyle=s.color+a+')';ctx.fillRect(-sz/2,-sz/3,sz,sz*.65);}
    else{ctx.beginPath();ctx.moveTo(0,-sz/2);ctx.lineTo(sz/2,sz/2);ctx.lineTo(-sz/2,sz/2);ctx.closePath();ctx.fillStyle=s.color+a+')';ctx.fill();}
    ctx.restore();
  });
  requestAnimationFrame(animate);
})();

// STATE
const MAX_ENTRIES=8,MIN_ENTRIES=1;
const reportData={name:'',date:'',period:'',done:[''],pending:[''],positive:[''],
  negative:[{text:'',solved:null,prio:null,by:'',how:''},{text:'',solved:null,prio:null,by:'',how:''},{text:'',solved:null,prio:null,by:'',how:''}],
  todos:[{task:'',until:''}]};
const STEPS=[
  {id:'done',icon:'✅',color:'#D1FAE5',title:'Erledigte Aufgaben',desc:'Was hast du heute erfolgreich abgeschlossen?',type:'list'},
  {id:'pending',icon:'⏳',color:'#DBEAFE',title:'Anstehende Aufgaben',desc:'Welche Aufgaben stehen noch aus oder wurden nicht fertig?',type:'list'},
  {id:'positive',icon:'⭐',color:'#FEF9C3',title:'Was war heute positiv?',desc:'Teile deine Erfolge, Highlights und guten Erlebnisse des Tages.',type:'list'},
  {id:'negative',icon:'⚠️',color:'#FEE2E2',title:'Was war heute negativ?',desc:'Welche Probleme oder Schwierigkeiten sind aufgetreten?',type:'negative'},
  {id:'todos',icon:'📋',color:'#F3E8FF',title:'To-Dos für die nächsten Tage',desc:'Was muss als nächstes erledigt werden?',type:'todos'},
];
let currentStep=0;

function goTo(id){document.querySelectorAll('.screen').forEach(s=>s.classList.remove('active'));document.getElementById('screen-'+id).classList.add('active');window.scrollTo({top:0,behavior:'smooth'});}

function startReport(){
  const name=document.getElementById('inp-name').value.trim();
  const date=document.getElementById('inp-date').value;
  let ok=true;
  if(!name){document.getElementById('err-name').classList.add('show');ok=false;}else document.getElementById('err-name').classList.remove('show');
  if(!date){document.getElementById('err-date').classList.add('show');ok=false;}else document.getElementById('err-date').classList.remove('show');
  if(!ok)return;
  reportData.name=name;reportData.date=date;reportData.period=document.getElementById('inp-period').value.trim();
  currentStep=0;renderStep();goTo('report');
}

function renderStep(){
  const step=STEPS[currentStep],total=STEPS.length;
  const pct=Math.round((currentStep/total)*100);
  document.getElementById('prog-label').textContent=`Schritt ${currentStep+1} von ${total}`;
  document.getElementById('prog-pct').textContent=pct+'%';
  document.getElementById('prog-fill').style.width=pct+'%';
  const dots=document.getElementById('step-dots');dots.innerHTML='';
  STEPS.forEach((_,i)=>{const d=document.createElement('div');d.className='step-dot'+(i<currentStep?' done':i===currentStep?' active':'');dots.appendChild(d);});
  document.getElementById('btn-back-report').style.visibility=currentStep===0?'hidden':'visible';
  document.getElementById('step-info').textContent=`${currentStep+1} / ${total}`;
  const nb=document.getElementById('btn-next-report');
  nb.innerHTML=currentStep===total-1
    ?'Abschließen <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>'
    :'Weiter <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>';
  const card=document.getElementById('section-card');
  if(step.type==='list')renderListSection(card,step);
  else if(step.type==='negative')renderNegativeSection(card,step);
  else renderTodosSection(card,step);
}

function renderListSection(card,step){
  const key=step.id,arr=reportData[key];
  card.innerHTML=`<div class="section-head"><div class="section-icon" style="background:${step.color};">${step.icon}</div><div><div class="section-title">${step.title}</div><div class="section-desc">${step.desc}</div></div></div>
  <div class="section-body"><div class="entries-list" id="entries-${key}"></div>
  <button class="add-entry-btn" id="add-btn-${key}" onclick="addEntry('${key}')"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12h14"/></svg>Eintrag hinzufügen</button>
  <div class="error-msg" id="err-${key}">Mindestens ein Eintrag ist erforderlich.</div></div>`;
  const list=document.getElementById('entries-'+key);
  arr.forEach((val,i)=>list.appendChild(makeEntryRow(key,i,val)));
  updateAddBtn(key);
}

function makeEntryRow(key,i,val){
  const row=document.createElement('div');row.className='entry-row';
  row.innerHTML=`<div class="entry-num">${i+1}</div><input class="entry-input" type="text" placeholder="Beschreibung …" value="${escHtml(val)}" oninput="reportData['${key}'][${i}]=this.value"><button class="remove-btn" onclick="removeEntry('${key}',${i})"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6L6 18M6 6l12 12"/></svg></button>`;
  return row;
}
function addEntry(key){if(reportData[key].length>=MAX_ENTRIES)return;reportData[key].push('');const i=reportData[key].length-1;const list=document.getElementById('entries-'+key);list.appendChild(makeEntryRow(key,i,''));updateAddBtn(key);list.lastChild.querySelector('input').focus();}
function removeEntry(key,idx){if(reportData[key].length<=MIN_ENTRIES)return;reportData[key].splice(idx,1);renderStep();}
function updateAddBtn(key){const btn=document.getElementById('add-btn-'+key);if(!btn)return;const full=reportData[key].length>=MAX_ENTRIES;btn.disabled=full;btn.style.opacity=full?'0.4':'1';btn.style.cursor=full?'not-allowed':'pointer';}

function renderNegativeSection(card,step){
  const negArr=reportData.negative;
  const blocksHtml=negArr.map((neg,i)=>`
    <div class="neg-block">
      <div class="neg-block-head"><div class="neg-block-title">Negativpunkt ${i+1}</div>${negArr.length>1?`<button class="remove-btn" onclick="removeNeg(${i})"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6L6 18M6 6l12 12"/></svg></button>`:''}</div>
      <div class="field-group" style="margin-bottom:0.5rem;"><label>Problem / Beschreibung</label><input class="entry-input" style="background:var(--surface);" type="text" placeholder="Was ist schiefgelaufen?" value="${escHtml(neg.text)}" oninput="reportData.negative[${i}].text=this.value"></div>
      <div class="radio-group"><label style="font-size:0.85rem;color:var(--text-muted);white-space:nowrap;">Gelöst?</label>
        <div class="radio-btn ${neg.solved===true?'selected':''}" onclick="setNegField(${i},'solved',true,this,'radio-btn')">✓ Ja</div>
        <div class="radio-btn ${neg.solved===false?'selected':''}" onclick="setNegField(${i},'solved',false,this,'radio-btn')">✕ Nein</div>
      </div>
      <div class="prio-group" id="prio-group-${i}" style="${neg.solved===false||neg.solved===null?'':'display:none'}">
        <div class="prio-label">Priorität (falls nicht gelöst)</div>
        <div class="prio-btns">
          <div class="prio-btn p1 ${neg.prio==='P1'?'selected':''}" onclick="setNegField(${i},'prio','P1',this,'prio-btn p1')"><div>Prio 1</div><div class="prio-sub">Kann warten bis Daniel kommt</div></div>
          <div class="prio-btn p2 ${neg.prio==='P2'?'selected':''}" onclick="setNegField(${i},'prio','P2',this,'prio-btn p2')"><div>Prio 2</div><div class="prio-sub">Sehr dringend – ohne Daniel nicht machbar</div></div>
          <div class="prio-btn p3 ${neg.prio==='P3'?'selected':''}" onclick="setNegField(${i},'prio','P3',this,'prio-btn p3')"><div>Prio 3</div><div class="prio-sub">Nicht so wichtig</div></div>
        </div>
      </div>
      <div class="inline-fields">
        <input class="mini-field" type="text" placeholder="Von wem gelöst?" value="${escHtml(neg.by)}" oninput="reportData.negative[${i}].by=this.value">
        <input class="mini-field" type="text" placeholder="Wie wurde es gelöst?" value="${escHtml(neg.how)}" oninput="reportData.negative[${i}].how=this.value">
      </div>
    </div>`).join('');
  card.innerHTML=`<div class="section-head"><div class="section-icon" style="background:${step.color};">${step.icon}</div><div><div class="section-title">${step.title}</div><div class="section-desc">${step.desc}</div></div></div>
  <div class="section-body">${blocksHtml}${negArr.length<MAX_ENTRIES?`<button class="add-entry-btn" onclick="addNeg()"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12h14"/></svg>Negativpunkt hinzufügen</button>`:''}
  <div class="error-msg" id="err-negative">Mindestens ein Negativpunkt mit Beschreibung ist erforderlich.</div></div>`;
}

function setNegField(i,field,val,el,btnClass){
  reportData.negative[i][field]=val;
  el.parentElement.querySelectorAll('.'+btnClass.split(' ')[0]).forEach(s=>s.classList.remove('selected'));
  el.classList.add('selected');
  if(field==='solved'){const pg=document.getElementById('prio-group-'+i);if(pg)pg.style.display=val===false?'':'none';if(val===true)reportData.negative[i].prio=null;}
}
function addNeg(){if(reportData.negative.length>=MAX_ENTRIES)return;reportData.negative.push({text:'',solved:null,prio:null,by:'',how:''});renderStep();}
function removeNeg(i){if(reportData.negative.length<=MIN_ENTRIES)return;reportData.negative.splice(i,1);renderStep();}

function renderTodosSection(card,step){
  const todos=reportData.todos;
  card.innerHTML=`<div class="section-head"><div class="section-icon" style="background:${step.color};">${step.icon}</div><div><div class="section-title">${step.title}</div><div class="section-desc">${step.desc}</div></div></div>
  <div class="section-body"><div class="entries-list" id="todos-list"></div>${todos.length<MAX_ENTRIES?`<button class="add-entry-btn" onclick="addTodo()"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12h14"/></svg>To-Do hinzufügen</button>`:''}
  <div class="error-msg" id="err-todos">Mindestens ein To-Do ist erforderlich.</div></div>`;
  const list=document.getElementById('todos-list');
  todos.forEach((t,i)=>{
    const row=document.createElement('div');row.className='entry-row';row.style.alignItems='center';
    row.innerHTML=`<div class="entry-num">${i+1}</div><input class="entry-input" type="text" placeholder="Aufgabe …" value="${escHtml(t.task)}" oninput="reportData.todos[${i}].task=this.value" style="flex:2;"><input class="entry-input" type="text" placeholder="Bis wann?" value="${escHtml(t.until)}" oninput="reportData.todos[${i}].until=this.value" style="flex:1;min-width:90px;"><button class="remove-btn" onclick="removeTodo(${i})"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6L6 18M6 6l12 12"/></svg></button>`;
    list.appendChild(row);
  });
}
function addTodo(){if(reportData.todos.length>=MAX_ENTRIES)return;reportData.todos.push({task:'',until:''});renderStep();}
function removeTodo(i){if(reportData.todos.length<=MIN_ENTRIES)return;reportData.todos.splice(i,1);renderStep();}

function reportBack(){if(currentStep===0){goTo('identity');return;}currentStep--;renderStep();window.scrollTo({top:0,behavior:'smooth'});}
function reportNext(){if(!validateCurrentStep())return;if(currentStep<STEPS.length-1){currentStep++;renderStep();window.scrollTo({top:0,behavior:'smooth'});}else{buildSuccess();}}

function validateCurrentStep(){
  const step=STEPS[currentStep];
  if(step.type==='list'){const filled=reportData[step.id].filter(v=>v.trim()!=='');if(filled.length<1){document.getElementById('err-'+step.id)?.classList.add('show');return false;}document.getElementById('err-'+step.id)?.classList.remove('show');return true;}
  if(step.type==='negative'){const filled=reportData.negative.filter(n=>n.text.trim()!=='');if(filled.length<1){document.getElementById('err-negative')?.classList.add('show');return false;}document.getElementById('err-negative')?.classList.remove('show');return true;}
  if(step.type==='todos'){const filled=reportData.todos.filter(t=>t.task.trim()!=='');if(filled.length<1){document.getElementById('err-todos')?.classList.add('show');return false;}document.getElementById('err-todos')?.classList.remove('show');return true;}
  return true;
}

function fmtDate(d){return d?new Date(d).toLocaleDateString('de-DE',{weekday:'long',year:'numeric',month:'long',day:'numeric'}):''}

function buildSuccess(){
  const dateStr=fmtDate(reportData.date);
  document.getElementById('sig-name').textContent=reportData.name;
  document.getElementById('sig-date').textContent=dateStr;

  const sections=[
    {label:'✅ Erledigte Aufgaben',items:reportData.done.filter(v=>v.trim())},
    {label:'⏳ Anstehende Aufgaben',items:reportData.pending.filter(v=>v.trim())},
    {label:'⭐ Positives',items:reportData.positive.filter(v=>v.trim())},
    {label:'⚠️ Negatives',items:reportData.negative.filter(n=>n.text.trim()).map(n=>{let s=n.text;if(n.solved!==null)s+=` (${n.solved?'Gelöst':'Nicht gelöst'}${n.prio?' – '+n.prio:''})`;return s;})},
    {label:'📋 To-Dos',items:reportData.todos.filter(t=>t.task.trim()).map(t=>t.until?`${t.task} → ${t.until}`:t.task)},
  ];
  const preview=document.getElementById('pdf-preview');
  preview.innerHTML='<div class="pdf-preview-title">Vorschau des Reports</div>'+
    sections.map(s=>`<div class="pdf-section"><div class="pdf-section-label">${s.label}</div>${s.items.map(it=>`<div class="pdf-section-item">• ${escHtml(it)}</div>`).join('')}</div>`).join('');
  goTo('success');
}

// PDF DOWNLOAD
function downloadPDF(){
  const {jsPDF}=window.jspdf;
  const doc=new jsPDF({orientation:'portrait',unit:'mm',format:'a4'});
  const W=210,margin=16,cW=W-margin*2,dateStr=fmtDate(reportData.date);
  let y=margin;

  // Orange header
  doc.setFillColor(249,115,22);
  doc.rect(0,0,W,30,'F');
  doc.setTextColor(255,255,255);
  doc.setFont('helvetica','bold');
  doc.setFontSize(22);
  doc.text('DAILY REPORT',margin,20);
  doc.setFontSize(9);
  doc.setFont('helvetica','normal');
  doc.text('Alltagshilfe Hannover',W-margin,20,{align:'right'});
  y=38;

  // Info row
  doc.setFillColor(245,243,239);
  doc.roundedRect(margin,y,cW,22,3,3,'F');
  doc.setFontSize(7.5);doc.setFont('helvetica','bold');doc.setTextColor(120,120,110);
  doc.text('MITARBEITER',margin+4,y+7);
  doc.text('DATUM',margin+cW/2+4,y+7);
  if(reportData.period)doc.text('ZEITRAUM',margin+cW*0.75+4,y+7);
  doc.setFontSize(10);doc.setFont('helvetica','bold');doc.setTextColor(26,26,24);
  doc.text(reportData.name,margin+4,y+16);
  doc.text(dateStr,margin+cW/2+4,y+16);
  if(reportData.period)doc.text(reportData.period,margin+cW*0.75+4,y+16);
  y+=30;

  const SC={done:[209,250,229,[5,150,105]],pending:[219,234,254,[37,99,235]],positive:[254,249,195,[161,98,7]],negative:[254,226,226,[220,38,38]],todos:[243,232,255,[109,40,217]]};

  function addSection(title,key,items){
    if(!items.length)return;
    if(y>260){doc.addPage();y=margin;}
    const [r,g,b,dk]=SC[key];
    doc.setFillColor(r,g,b);
    doc.roundedRect(margin,y,cW,9,2,2,'F');
    doc.setTextColor(...dk);doc.setFont('helvetica','bold');doc.setFontSize(8.5);
    doc.text(title,margin+3,y+6.2);
    y+=13;
    doc.setTextColor(40,40,38);doc.setFont('helvetica','normal');doc.setFontSize(9.5);
    items.forEach((item,i)=>{
      if(y>272){doc.addPage();y=margin;}
      const lines=doc.splitTextToSize(`${i+1}.  ${item}`,cW-8);
      doc.text(lines,margin+5,y);
      y+=lines.length*5.8;
    });
    y+=5;
  }

  addSection('✓  Erledigte Aufgaben','done',reportData.done.filter(v=>v.trim()));
  addSection('⏳  Anstehende Aufgaben','pending',reportData.pending.filter(v=>v.trim()));
  addSection('★  Was war positiv?','positive',reportData.positive.filter(v=>v.trim()));
  addSection('!  Was war negativ?','negative',reportData.negative.filter(n=>n.text.trim()).map(n=>{let s=n.text;if(n.solved!==null)s+=` | Gelöst: ${n.solved?'Ja':'Nein'}`;if(n.solved===false&&n.prio)s+=` | Priorität: ${n.prio}`;if(n.by)s+=` | Von: ${n.by}`;if(n.how)s+=` | Wie: ${n.how}`;return s;}));
  addSection('►  To-Dos','todos',reportData.todos.filter(t=>t.task.trim()).map(t=>t.until?`${t.task}  →  Bis: ${t.until}`:t.task));

  // Signature area
  if(y>258){doc.addPage();y=margin;}
  y+=4;
  doc.setDrawColor(220,220,215);doc.setLineWidth(0.3);doc.line(margin,y,W-margin,y);
  y+=8;
  doc.setFillColor(249,115,22);doc.rect(margin,y,2.5,18,'F');
  doc.setTextColor(130,120,110);doc.setFontSize(7.5);doc.setFont('helvetica','normal');
  doc.text('SIGNIERT VON',margin+6,y+6);
  doc.setTextColor(26,26,24);doc.setFontSize(13);doc.setFont('helvetica','bold');
  doc.text(reportData.name,margin+6,y+14);
  doc.setTextColor(130,120,110);doc.setFontSize(8);doc.setFont('helvetica','normal');
  doc.text(dateStr,W-margin,y+6,{align:'right'});
  doc.text('Alltagshilfe Hannover',W-margin,y+14,{align:'right'});
  y+=22;
  doc.setDrawColor(26,26,24);doc.setLineWidth(0.5);doc.line(margin+6,y,margin+65,y);
  doc.setTextColor(150,140,130);doc.setFontSize(7);
  doc.text('Unterschrift',margin+6,y+4);

  // Footer
  doc.setFillColor(249,115,22);doc.rect(0,286,W,11,'F');
  doc.setTextColor(255,255,255);doc.setFontSize(7.5);doc.setFont('helvetica','normal');
  doc.text(`Daily Report  ·  ${reportData.name}  ·  ${dateStr}  ·  Alltagshilfe Hannover`,W/2,292.5,{align:'center'});

  doc.save(`Daily_Report_${reportData.name.replace(/ /g,'_')}_${reportData.date}.pdf`);
}

// SHARE – opens Mail app with recipient, subject and full report pre-filled
function shareReport(){
  const dateStr = fmtDate(reportData.date);
  const L1 = '==================================================';
  const L2 = '--------------------------------------';

  let body = '';
  body += 'DAILY REPORT - Alltagshilfe Hannover\n' + L1 + '\n';
  body += 'Mitarbeiter : ' + reportData.name + '\n';
  body += 'Datum       : ' + dateStr + '\n';
  if(reportData.period) body += 'Zeitraum    : ' + reportData.period + '\n';
  body += L1 + '\n\n';

  body += 'ERLEDIGTE AUFGABEN\n' + L2 + '\n';
  reportData.done.filter(v=>v.trim()).forEach((v,i)=>{ body += '  '+(i+1)+'. '+v+'\n'; });
  body += '\n';

  body += 'ANSTEHENDE AUFGABEN\n' + L2 + '\n';
  reportData.pending.filter(v=>v.trim()).forEach((v,i)=>{ body += '  '+(i+1)+'. '+v+'\n'; });
  body += '\n';

  body += 'WAS WAR POSITIV?\n' + L2 + '\n';
  reportData.positive.filter(v=>v.trim()).forEach((v,i)=>{ body += '  '+(i+1)+'. '+v+'\n'; });
  body += '\n';

  body += 'WAS WAR NEGATIV?\n' + L2 + '\n';
  reportData.negative.filter(n=>n.text.trim()).forEach((n,i)=>{
    body += '  '+(i+1)+'. '+n.text+'\n';
    if(n.solved!==null) body += '     Geloest     : '+(n.solved?'Ja':'Nein')+'\n';
    if(n.solved===false&&n.prio) body += '     Prioritaet  : '+n.prio+'\n';
    if(n.by)  body += '     Von wem     : '+n.by+'\n';
    if(n.how) body += '     Wie geloest : '+n.how+'\n';
  });
  body += '\n';

  body += 'TO-DOS FUER DIE NAECHSTEN TAGE\n' + L2 + '\n';
  reportData.todos.filter(t=>t.task.trim()).forEach((t,i)=>{
    body += '  '+(i+1)+'. '+t.task;
    if(t.until) body += '  ->  Bis: '+t.until;
    body += '\n';
  });
  body += '\n';

  body += L1 + '\n';
  body += 'Signiert von : ' + reportData.name + '\n';
  body += 'Datum        : ' + dateStr + '\n';
  body += 'Alltagshilfe Hannover\n';

  const subject = 'Daily Report - ' + reportData.name + ' - ' + dateStr;
  const mailto  = 'mailto:' + encodeURIComponent(EMPFAENGER_EMAIL)
                + '?subject=' + encodeURIComponent(subject)
                + '&body='    + encodeURIComponent(body);

  // Hidden anchor click – most reliable on iOS Safari and all desktop browsers
  const a = document.createElement('a');
  a.href = mailto;
  a.style.display = 'none';
  document.body.appendChild(a);
  a.click();
  setTimeout(()=>{ if(document.body.contains(a)) document.body.removeChild(a); }, 400);
}

function resetAll(){
  reportData.name='';reportData.date='';reportData.period='';
  reportData.done=[''];reportData.pending=[''];reportData.positive=[''];
  reportData.negative=[{text:'',solved:null,prio:null,by:'',how:''},{text:'',solved:null,prio:null,by:'',how:''},{text:'',solved:null,prio:null,by:'',how:''}];
  reportData.todos=[{task:'',until:''}];
  document.getElementById('inp-name').value='';
  document.getElementById('inp-date').value=new Date().toISOString().split('T')[0];
  document.getElementById('inp-period').value='';
  currentStep=0;goTo('landing');
}
function escHtml(str){return(str||'').replace(/&/g,'&amp;').replace(/"/g,'&quot;').replace(/</g,'&lt;').replace(/>/g,'&gt;');}
document.getElementById('inp-date').value=new Date().toISOString().split('T')[0];
</script>
