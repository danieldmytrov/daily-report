<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Daily Report – Mitarbeiterportal</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<script src="https://cdn.emailjs.com/dist/email.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
<style>
/* ── TOKENS ─────────────────────────────────────────────── */
:root {
  --orange:#F97316; --orange-light:#FED7AA; --orange-dark:#C2410C;
  --orange-glow:rgba(249,115,22,0.15);
  --bg:#FAFAF8; --surface:#FFFFFF; --surface2:#F5F3EF;
  --text:#1A1A18; --text-muted:#6B6B60;
  --border:rgba(0,0,0,0.08);
  --radius:16px; --radius-sm:10px;
  --shadow:0 4px 24px rgba(0,0,0,0.06),0 1px 4px rgba(0,0,0,0.04);
  --shadow-lg:0 20px 60px rgba(0,0,0,0.10),0 4px 16px rgba(0,0,0,0.06);
  /* Fluid spacing */
  --sp-xs:clamp(0.5rem,1vw,0.75rem);
  --sp-sm:clamp(0.75rem,1.5vw,1rem);
  --sp-md:clamp(1rem,2vw,1.5rem);
  --sp-lg:clamp(1.25rem,3vw,2rem);
  --sp-xl:clamp(1.5rem,4vw,3rem);
  /* Fluid card padding */
  --card-pad:clamp(1.25rem,4vw,3rem);
}

/* ── RESET & BASE ────────────────────────────────────────── */
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box;}
html{scroll-behavior:smooth;-webkit-text-size-adjust:100%;}
body{font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--text);min-height:100vh;overflow-x:hidden;-webkit-font-smoothing:antialiased;}

/* ── CANVAS ──────────────────────────────────────────────── */
#bg-canvas{position:fixed;top:0;left:0;width:100%;height:100%;z-index:0;pointer-events:none;}

/* ── SCREENS ─────────────────────────────────────────────── */
.screen{position:relative;z-index:1;display:none;min-height:100vh;align-items:center;justify-content:center;padding:var(--sp-lg);}
.screen.active{display:flex;}

/* ── ANIMATIONS ──────────────────────────────────────────── */
@keyframes fadeUp{from{opacity:0;transform:translateY(20px);}to{opacity:1;transform:translateY(0);}}
@keyframes slideIn{from{opacity:0;transform:translateY(24px) scale(0.98);}to{opacity:1;transform:translateY(0) scale(1);}}
@keyframes bounceIn{0%{transform:scale(0);}60%{transform:scale(1.15);}100%{transform:scale(1);}}
@keyframes pulse{0%,100%{opacity:1;transform:scale(1);}50%{opacity:0.5;transform:scale(1.4);}}
@keyframes spin{to{transform:rotate(360deg);}}

/* ── LANDING ─────────────────────────────────────────────── */
#screen-landing{flex-direction:column;text-align:center;gap:0;padding:var(--sp-xl) var(--sp-lg);}
.landing-badge{display:inline-flex;align-items:center;gap:8px;background:var(--orange-glow);border:1px solid rgba(249,115,22,0.25);color:var(--orange-dark);font-size:clamp(11px,1.5vw,13px);font-weight:500;letter-spacing:0.08em;text-transform:uppercase;padding:6px 16px;border-radius:100px;margin-bottom:var(--sp-lg);animation:fadeUp 0.6s ease both;}
.badge-dot{width:6px;height:6px;border-radius:50%;background:var(--orange);animation:pulse 2s infinite;flex-shrink:0;}
.landing-title{font-family:'Syne',sans-serif;font-size:clamp(2.8rem,9vw,6.5rem);font-weight:800;line-height:0.93;letter-spacing:-0.03em;animation:fadeUp 0.6s 0.1s ease both;}
.landing-title span{color:var(--orange);}
.landing-sub{margin-top:var(--sp-md);font-size:clamp(0.95rem,2vw,1.2rem);color:var(--text-muted);font-weight:300;line-height:1.65;max-width:min(480px,90vw);animation:fadeUp 0.6s 0.2s ease both;}
.btn-primary{margin-top:var(--sp-xl);display:inline-flex;align-items:center;gap:10px;background:var(--orange);color:#fff;font-family:'Syne',sans-serif;font-size:clamp(0.95rem,2vw,1.05rem);font-weight:600;padding:clamp(14px,2vw,18px) clamp(28px,4vw,40px);border-radius:100px;border:none;cursor:pointer;transition:all 0.25s;box-shadow:0 8px 32px rgba(249,115,22,0.35);animation:fadeUp 0.6s 0.3s ease both;touch-action:manipulation;}
.btn-primary:hover,.btn-primary:focus-visible{background:var(--orange-dark);transform:translateY(-2px);box-shadow:0 12px 40px rgba(249,115,22,0.45);}
.btn-primary:active{transform:translateY(0);}
.landing-stats{display:flex;gap:clamp(1.5rem,5vw,3.5rem);margin-top:clamp(2.5rem,5vw,4rem);animation:fadeUp 0.6s 0.4s ease both;flex-wrap:wrap;justify-content:center;}
.stat-item{text-align:center;}
.stat-num{font-family:'Syne',sans-serif;font-size:clamp(1.6rem,4vw,2.2rem);font-weight:700;color:var(--orange);}
.stat-label{font-size:clamp(0.7rem,1.2vw,0.8rem);color:var(--text-muted);text-transform:uppercase;letter-spacing:0.06em;margin-top:2px;}

/* ── FORM CARDS (Identity + Success) ────────────────────── */
#screen-identity,#screen-success{align-items:flex-start;justify-content:center;padding:var(--sp-lg) var(--sp-md);}
.form-card,.success-card{background:var(--surface);border-radius:var(--radius);box-shadow:var(--shadow-lg);border:1px solid var(--border);padding:var(--card-pad);width:100%;animation:slideIn 0.4s ease;}
.form-card{max-width:560px;}
.success-card{max-width:680px;}
.card-icon{width:clamp(44px,6vw,52px);height:clamp(44px,6vw,52px);border-radius:14px;background:var(--orange-glow);display:flex;align-items:center;justify-content:center;margin-bottom:var(--sp-md);font-size:clamp(20px,3vw,24px);}
.card-title{font-family:'Syne',sans-serif;font-size:clamp(1.5rem,3.5vw,1.85rem);font-weight:700;letter-spacing:-0.02em;margin-bottom:0.4rem;}
.card-sub{font-size:clamp(0.875rem,1.5vw,0.95rem);color:var(--text-muted);margin-bottom:var(--sp-lg);line-height:1.55;}
.field-group{display:flex;flex-direction:column;gap:0.45rem;margin-bottom:1.1rem;}
label{font-size:0.85rem;font-weight:500;color:var(--text);letter-spacing:0.02em;}
input[type=text],input[type=date],input[type=email]{border:1.5px solid var(--border);border-radius:var(--radius-sm);padding:clamp(11px,2vw,14px) clamp(12px,2vw,16px);font-family:'DM Sans',sans-serif;font-size:clamp(0.95rem,2vw,1rem);color:var(--text);background:var(--surface);outline:none;transition:border-color 0.2s,box-shadow 0.2s;width:100%;-webkit-appearance:none;appearance:none;}
input:focus{border-color:var(--orange);box-shadow:0 0 0 3px var(--orange-glow);}

/* ── REPORT SCREEN ───────────────────────────────────────── */
#screen-report{align-items:flex-start;justify-content:center;padding:var(--sp-md) var(--sp-sm);}
.report-wrapper{width:100%;max-width:800px;margin:0 auto;display:flex;flex-direction:column;gap:0;}
.progress-header{background:var(--surface);border-radius:var(--radius);border:1px solid var(--border);padding:clamp(1rem,2.5vw,1.5rem) clamp(1rem,3vw,2rem);margin-bottom:var(--sp-md);box-shadow:var(--shadow);}
.progress-top{display:flex;justify-content:space-between;align-items:center;margin-bottom:0.875rem;}
.progress-label{font-family:'Syne',sans-serif;font-size:clamp(0.75rem,1.5vw,0.9rem);font-weight:600;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.06em;}
.progress-pct{font-family:'Syne',sans-serif;font-size:clamp(1rem,2vw,1.1rem);font-weight:700;color:var(--orange);}
.progress-track{height:6px;background:var(--surface2);border-radius:100px;overflow:hidden;}
.progress-fill{height:100%;background:linear-gradient(90deg,var(--orange),#FB923C);border-radius:100px;transition:width 0.5s ease;}
.step-dots{display:flex;gap:5px;margin-top:0.65rem;flex-wrap:wrap;}
.step-dot{width:22px;height:5px;border-radius:100px;background:var(--surface2);transition:all 0.3s;}
.step-dot.done{background:var(--orange);}
.step-dot.active{background:var(--orange-light);width:36px;}
.section-card{background:var(--surface);border-radius:var(--radius);border:1px solid var(--border);box-shadow:var(--shadow);overflow:hidden;animation:slideIn 0.35s ease;}
.section-head{padding:clamp(1rem,2.5vw,1.75rem) clamp(1rem,3vw,2rem) clamp(0.75rem,2vw,1.25rem);border-bottom:1px solid var(--border);display:flex;align-items:center;gap:clamp(0.75rem,2vw,1rem);}
.section-icon{width:clamp(38px,5vw,46px);height:clamp(38px,5vw,46px);border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:clamp(18px,2.5vw,22px);flex-shrink:0;}
.section-title{font-family:'Syne',sans-serif;font-size:clamp(1.1rem,2.5vw,1.35rem);font-weight:700;letter-spacing:-0.02em;}
.section-desc{font-size:clamp(0.78rem,1.5vw,0.87rem);color:var(--text-muted);margin-top:2px;line-height:1.45;}
.section-body{padding:clamp(1rem,2.5vw,1.5rem) clamp(1rem,3vw,2rem) clamp(1.25rem,3vw,2rem);}
.entries-list{display:flex;flex-direction:column;gap:0.65rem;margin-bottom:0.875rem;}
.entry-row{display:flex;align-items:center;gap:0.6rem;animation:fadeUp 0.2s ease;}
.entry-num{width:28px;height:28px;border-radius:8px;background:var(--surface2);display:flex;align-items:center;justify-content:center;font-size:0.72rem;font-weight:600;color:var(--text-muted);flex-shrink:0;}
.entry-input{flex:1;border:1.5px solid var(--border);border-radius:var(--radius-sm);padding:clamp(10px,1.5vw,12px) clamp(10px,2vw,14px);font-family:'DM Sans',sans-serif;font-size:clamp(0.9rem,1.8vw,0.95rem);color:var(--text);background:var(--bg);outline:none;transition:border-color 0.2s,background 0.2s;-webkit-appearance:none;appearance:none;min-width:0;}
.entry-input:focus{border-color:var(--orange);background:var(--surface);box-shadow:0 0 0 3px var(--orange-glow);}
.remove-btn{width:32px;height:32px;border:none;background:none;cursor:pointer;color:var(--text-muted);opacity:0.4;border-radius:8px;display:flex;align-items:center;justify-content:center;transition:all 0.2s;flex-shrink:0;touch-action:manipulation;}
.remove-btn:hover,.remove-btn:focus-visible{opacity:1;color:#EF4444;background:#FEF2F2;}
.add-entry-btn{display:inline-flex;align-items:center;justify-content:center;gap:6px;background:var(--surface2);border:1.5px dashed rgba(0,0,0,0.12);color:var(--text-muted);font-family:'DM Sans',sans-serif;font-size:clamp(0.82rem,1.5vw,0.875rem);font-weight:500;padding:clamp(9px,1.5vw,11px) 16px;border-radius:var(--radius-sm);cursor:pointer;transition:all 0.2s;width:100%;margin-top:0.5rem;touch-action:manipulation;}
.add-entry-btn:hover,.add-entry-btn:focus-visible{background:var(--orange-glow);border-color:var(--orange);color:var(--orange-dark);}

/* Negative blocks */
.neg-block{background:var(--bg);border:1px solid var(--border);border-radius:var(--radius-sm);padding:clamp(1rem,2.5vw,1.25rem);margin-bottom:0.875rem;}
.neg-block-head{display:flex;justify-content:space-between;align-items:center;margin-bottom:0.65rem;}
.neg-block-title{font-weight:600;font-size:0.9rem;color:#EF4444;}
.radio-group{display:flex;gap:0.5rem;margin-top:0.65rem;align-items:center;flex-wrap:wrap;}
.radio-btn{flex:1;min-width:70px;padding:clamp(8px,1.5vw,10px) 10px;border-radius:var(--radius-sm);border:1.5px solid var(--border);background:var(--surface);cursor:pointer;text-align:center;font-size:clamp(0.78rem,1.4vw,0.82rem);font-weight:500;transition:all 0.2s;user-select:none;touch-action:manipulation;}
.radio-btn:hover{border-color:var(--orange);color:var(--orange-dark);}
.radio-btn.selected{background:var(--orange);border-color:var(--orange);color:white;}
.prio-group{margin-top:0.875rem;}
.prio-label{font-size:0.78rem;font-weight:600;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.05em;margin-bottom:0.45rem;}
.prio-btns{display:flex;gap:0.5rem;}
.prio-btn{flex:1;padding:clamp(7px,1.5vw,9px) 5px;border-radius:var(--radius-sm);border:1.5px solid var(--border);background:var(--surface);cursor:pointer;text-align:center;font-size:clamp(0.75rem,1.3vw,0.8rem);font-weight:600;transition:all 0.2s;user-select:none;line-height:1.3;touch-action:manipulation;}
.prio-btn .prio-sub{font-size:clamp(0.62rem,1.1vw,0.68rem);font-weight:400;opacity:0.75;margin-top:2px;line-height:1.3;}
.prio-btn.p1.selected{background:#1D4ED8;border-color:#1D4ED8;color:white;}
.prio-btn.p2.selected{background:#DC2626;border-color:#DC2626;color:white;}
.prio-btn.p3.selected{background:#6B7280;border-color:#6B7280;color:white;}
.inline-fields{display:flex;gap:0.5rem;margin-top:0.65rem;flex-wrap:wrap;}
.mini-field{flex:1;border:1.5px solid var(--border);border-radius:var(--radius-sm);padding:clamp(9px,1.5vw,11px) clamp(10px,2vw,12px);font-family:'DM Sans',sans-serif;font-size:clamp(0.86rem,1.5vw,0.9rem);color:var(--text);background:var(--surface);outline:none;transition:border-color 0.2s;min-width:min(0px,100%);}
.mini-field:focus{border-color:var(--orange);box-shadow:0 0 0 3px var(--orange-glow);}

/* Nav footer */
.nav-footer{display:flex;align-items:center;justify-content:space-between;gap:0.75rem;margin-top:var(--sp-md);flex-wrap:wrap;}
.btn-back{display:inline-flex;align-items:center;gap:7px;background:none;border:1.5px solid var(--border);color:var(--text-muted);font-family:'DM Sans',sans-serif;font-size:clamp(0.875rem,1.8vw,0.95rem);font-weight:500;padding:clamp(11px,1.8vw,13px) clamp(16px,3vw,24px);border-radius:100px;cursor:pointer;transition:all 0.2s;touch-action:manipulation;white-space:nowrap;}
.btn-back:hover{background:var(--surface2);color:var(--text);}
.btn-next{display:inline-flex;align-items:center;gap:9px;background:var(--orange);color:#fff;font-family:'Syne',sans-serif;font-size:clamp(0.9rem,1.8vw,1rem);font-weight:600;padding:clamp(11px,1.8vw,13px) clamp(20px,4vw,32px);border-radius:100px;border:none;cursor:pointer;transition:all 0.25s;box-shadow:0 6px 20px rgba(249,115,22,0.3);touch-action:manipulation;white-space:nowrap;}
.btn-next:hover{background:var(--orange-dark);transform:translateY(-1px);}
.step-info{font-size:0.85rem;color:var(--text-muted);white-space:nowrap;}
.error-msg{color:#EF4444;font-size:0.83rem;margin-top:0.4rem;display:none;}
.error-msg.show{display:block;}

/* ── SUCCESS SCREEN ──────────────────────────────────────── */
.success-top{display:flex;align-items:center;gap:var(--sp-sm);margin-bottom:0.65rem;}
.success-icon{width:clamp(48px,6vw,60px);height:clamp(48px,6vw,60px);border-radius:50%;background:#D1FAE5;display:flex;align-items:center;justify-content:center;font-size:clamp(22px,3vw,28px);flex-shrink:0;animation:bounceIn 0.5s ease;}
.success-title{font-family:'Syne',sans-serif;font-size:clamp(1.4rem,3.5vw,1.85rem);font-weight:800;letter-spacing:-0.02em;}
.success-sub{font-size:clamp(0.85rem,1.5vw,0.92rem);color:var(--text-muted);line-height:1.6;margin-bottom:var(--sp-md);}
.pdf-preview{background:var(--surface2);border-radius:var(--radius-sm);border:1px solid var(--border);padding:clamp(1rem,2vw,1.5rem);max-height:clamp(160px,25vh,240px);overflow-y:auto;margin-bottom:var(--sp-md);}
.pdf-preview-title{font-size:0.7rem;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:var(--text-muted);margin-bottom:0.65rem;}
.pdf-section{margin-bottom:0.65rem;}
.pdf-section-label{font-size:0.7rem;font-weight:700;text-transform:uppercase;letter-spacing:0.06em;color:var(--orange-dark);margin-bottom:0.2rem;}
.pdf-section-item{font-size:clamp(0.82rem,1.5vw,0.87rem);color:var(--text);line-height:1.5;padding-left:0.6rem;}
.signature-block{background:var(--surface2);border-radius:var(--radius-sm);border:1px solid var(--border);padding:clamp(0.875rem,2vw,1.25rem);display:flex;align-items:center;gap:var(--sp-md);margin-bottom:var(--sp-md);}
.sig-icon{font-size:clamp(1.5rem,3vw,1.85rem);flex-shrink:0;}
.sig-info{flex:1;min-width:0;}
.sig-label{font-size:0.7rem;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.06em;}
.sig-name{font-family:'Syne',sans-serif;font-size:clamp(0.95rem,2vw,1.1rem);font-weight:700;color:var(--text);margin-top:2px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
.sig-date{font-size:clamp(0.75rem,1.3vw,0.8rem);color:var(--text-muted);margin-top:1px;}
.sig-underline{border-top:2px solid var(--orange);padding-top:4px;margin-top:4px;font-size:0.68rem;color:var(--text-muted);letter-spacing:0.04em;}
.action-btns{display:flex;gap:0.65rem;flex-wrap:wrap;}
.btn-action{display:inline-flex;align-items:center;gap:8px;font-family:'Syne',sans-serif;font-size:clamp(0.85rem,1.8vw,0.92rem);font-weight:600;padding:clamp(11px,1.8vw,13px) clamp(16px,3vw,22px);border-radius:100px;border:none;cursor:pointer;transition:all 0.25s;flex:1;justify-content:center;min-width:130px;touch-action:manipulation;white-space:nowrap;}
.btn-download{background:var(--orange);color:#fff;box-shadow:0 6px 20px rgba(249,115,22,0.3);}
.btn-download:hover{background:var(--orange-dark);transform:translateY(-1px);}
.btn-share{background:var(--surface);color:var(--text);border:1.5px solid var(--border);}
.btn-share:hover{background:var(--surface2);}
.btn-new{background:none;color:var(--text-muted);border:1.5px solid var(--border);font-size:clamp(0.82rem,1.5vw,0.87rem);font-weight:400;font-family:'DM Sans',sans-serif;margin-top:0.5rem;width:100%;flex:none;}
.btn-new:hover{background:var(--surface2);color:var(--text);}

/* ── LOADING ─────────────────────────────────────────────── */
#loading-overlay{display:none;position:fixed;inset:0;background:rgba(255,255,255,0.88);z-index:100;align-items:center;justify-content:center;flex-direction:column;gap:1rem;backdrop-filter:blur(6px);}
#loading-overlay.active{display:flex;}
.spinner{width:48px;height:48px;border:3px solid var(--orange-light);border-top-color:var(--orange);border-radius:50%;animation:spin 0.7s linear infinite;}
.loading-text{font-family:'Syne',sans-serif;font-weight:600;color:var(--text-muted);}

/* ── IDENTITY/SUCCESS TOP PADDING FIX ────────────────────── */
#screen-identity{min-height:100vh;padding-top:clamp(1.5rem,4vh,3rem);padding-bottom:clamp(1.5rem,4vh,3rem);}
#screen-success{min-height:100vh;padding-top:clamp(1.5rem,4vh,3rem);padding-bottom:clamp(1.5rem,4vh,3rem);}
#screen-report{min-height:100vh;padding-top:clamp(1rem,2.5vh,2rem);padding-bottom:clamp(1.5rem,4vh,3rem);}

/* ── TABLET (768–1024px) ─────────────────────────────────── */
@media(min-width:768px) and (max-width:1024px){
  .form-card{max-width:600px;}
  .success-card{max-width:700px;}
  .report-wrapper{max-width:720px;}
  .prio-btns{gap:0.65rem;}
  .action-btns{gap:0.75rem;}
  .nav-footer{flex-wrap:nowrap;}
}

/* ── MOBILE (≤767px) ─────────────────────────────────────── */
@media(max-width:767px){
  /* Layout */
  .screen{padding:1rem 0.875rem;}
  #screen-identity,#screen-success{padding:1rem 0.875rem;}
  #screen-report{padding:0.875rem 0.75rem;}

  /* Landing */
  .landing-title{font-size:clamp(2.6rem,13vw,4rem);}
  .landing-stats{gap:1.75rem;margin-top:2rem;}

  /* Cards */
  .form-card,.success-card{padding:1.5rem 1.25rem;border-radius:14px;}

  /* Section card */
  .section-head{padding:1rem 1rem 0.875rem;gap:0.75rem;}
  .section-icon{width:38px;height:38px;font-size:18px;}
  .section-title{font-size:1.05rem;}
  .section-desc{font-size:0.78rem;}
  .section-body{padding:1rem 1rem 1.25rem;}

  /* Inputs — prevent iOS zoom (must be ≥16px) */
  input[type=text],input[type=date],input[type=email],.entry-input,.mini-field{font-size:16px !important;}

  /* Entries */
  .entry-num{width:24px;height:24px;font-size:0.68rem;}
  .remove-btn{width:36px;height:36px;}

  /* Prio buttons: stack on very small screens */
  .prio-btns{flex-direction:column;gap:0.4rem;}
  .prio-btn{padding:10px 8px;}
  .prio-btn .prio-sub{font-size:0.7rem;opacity:0.8;}

  /* Inline fields: stack */
  .inline-fields{flex-direction:column;}
  .mini-field{min-width:100%;flex:none;}

  /* Nav footer */
  .nav-footer{flex-wrap:nowrap;gap:0.5rem;}
  .btn-back{padding:11px 14px;font-size:0.875rem;}
  .btn-next{padding:11px 18px;font-size:0.875rem;flex:1;justify-content:center;}
  .step-info{display:none;}

  /* Success action buttons */
